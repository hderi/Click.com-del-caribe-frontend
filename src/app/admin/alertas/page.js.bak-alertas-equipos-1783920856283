"use client";

import { useEffect, useMemo, useState } from "react";
import Link from "next/link";

const API_URL = process.env.NEXT_PUBLIC_API_URL || "http://localhost:3001";

function authHeaders() {
  if (typeof window === "undefined") return {};
  const token = localStorage.getItem("clickcom_token") || "";
  return token ? { Authorization: `Bearer ${token}` } : {};
}

function normalizeList(data) {
  if (Array.isArray(data)) return data;
  if (Array.isArray(data.reparaciones)) return data.reparaciones;
  if (Array.isArray(data.items)) return data.items;
  return [];
}

function onlyDate(value) {
  if (!value) return "";
  const raw = String(value);
  if (/^\d{4}-\d{2}-\d{2}/.test(raw)) return raw.slice(0, 10);
  const date = new Date(raw);
  if (Number.isNaN(date.getTime())) return "";
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, "0");
  const d = String(date.getDate()).padStart(2, "0");
  return `${y}-${m}-${d}`;
}

function daysBetween(dateText, todayText) {
  if (!dateText || !todayText) return 0;
  const a = new Date(dateText + "T00:00:00");
  const b = new Date(todayText + "T00:00:00");
  return Math.floor((b - a) / 86400000);
}

function getFolio(item) {
  return item.folio || item.id || item.codigo || "Sin folio";
}

function getEstado(item) {
  return String(item.estado || item.status || "").toLowerCase();
}

function getFechaIngreso(item) {
  return onlyDate(item.fechaIngreso || item.fecha_ingreso || item.ingreso || item.creadoEn || item.creado_en || item.fecha);
}

function getFechaEntrega(item) {
  return onlyDate(
    item.fechaEntregaEstimada ||
    item.fecha_entrega_estimada ||
    item.entregaEstimada ||
    item.fechaEstimada ||
    item.fecha_estimada ||
    item.fechaEntrega ||
    item.entrega
  );
}

function getLastMove(item) {
  const hist = item.historial || item.timeline || item.avances || [];
  if (Array.isArray(hist) && hist.length) {
    const dates = hist
      .map((h) => onlyDate(h.fecha || h.creadoEn || h.creado_en || h.date))
      .filter(Boolean)
      .sort();
    if (dates.length) return dates[dates.length - 1];
  }
  return onlyDate(item.actualizadoEn || item.actualizado_en || item.updated_at || item.creadoEn || item.creado_en || getFechaIngreso(item));
}

function isClosed(item) {
  const estado = getEstado(item);
  return ["entregado", "cerrado", "cancelado"].includes(estado);
}

function isReadyNotPicked(item) {
  const estado = getEstado(item);
  return ["finalizado", "listo", "lista"].includes(estado);
}

function AlertCard({ title, value, subtitle, color = "#0A84C6" }) {
  return (
    <article className="rounded-2xl border border-[#B9D0DF] bg-white p-5 shadow-sm">
      <div className="flex items-start justify-between gap-3">
        <div>
          <p className="text-sm font-bold text-[#102033]">{title}</p>
          <p className="mt-4 text-4xl font-black" style={{ color }}>{value}</p>
          <p className="mt-1 text-xs font-bold uppercase tracking-[0.18em] text-[#5D7186]">{subtitle}</p>
        </div>
        <span className="h-3 w-3 rounded-full" style={{ backgroundColor: color }} />
      </div>
    </article>
  );
}

function AlertRow({ item, label, detail, tag }) {
  const folio = getFolio(item);
  return (
    <div className="flex flex-col gap-3 rounded-2xl border border-[#C5D9E7] bg-[#F8FCFF] p-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p className="text-sm font-black text-[#102033]">{folio} · {item.clienteNombre || item.cliente || item.nombreCliente || "Cliente"}</p>
        <p className="mt-1 text-sm font-semibold text-[#41566C]">{label}</p>
        <p className="mt-1 text-xs text-[#60758B]">{detail}</p>
      </div>
      <div className="flex items-center gap-2">
        <span className="rounded-full bg-[#FFF0E5] px-3 py-1 text-xs font-black text-[#C25A00]">{tag}</span>
        <Link href={`/admin/reparaciones/${folio}`} className="rounded-xl bg-[#0A84C6] px-4 py-2 text-sm font-black text-white hover:bg-[#096EA5]">
          Ver orden
        </Link>
      </div>
    </div>
  );
}

export default function AlertasPage() {
  const [reparaciones, setReparaciones] = useState([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState("");

  useEffect(() => {
    let ignore = false;
    async function load() {
      try {
        setLoading(true);
        const res = await fetch(`${API_URL}/api/reparaciones`, { headers: authHeaders() });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || "No se pudieron cargar las reparaciones");
        if (!ignore) setReparaciones(normalizeList(data));
      } catch (err) {
        if (!ignore) setError(err.message || "Error al cargar alertas");
      } finally {
        if (!ignore) setLoading(false);
      }
    }
    load();
    return () => { ignore = true; };
  }, []);

  const today = onlyDate(new Date());

  const alertas = useMemo(() => {
    const abiertas = reparaciones.filter((item) => !isClosed(item));
    const fechaVencida = abiertas.filter((item) => {
      const entrega = getFechaEntrega(item);
      return entrega && entrega < today;
    });
    const sinMovimiento = abiertas.filter((item) => {
      const last = getLastMove(item);
      return last && daysBetween(last, today) > 3;
    });
    const sinRecoger = reparaciones.filter(isReadyNotPicked);
    return { abiertas, fechaVencida, sinMovimiento, sinRecoger };
  }, [reparaciones, today]);

  return (
    <div className="space-y-6">
      <section className="rounded-3xl border border-[#B9D0DF] bg-[#F7FBFE] p-6 shadow-sm">
        <p className="text-xs font-black uppercase tracking-[0.22em] text-[#FF6B00]">Centro de avisos</p>
        <h1 className="mt-2 text-3xl font-black text-[#07192D]">Alertas del taller</h1>
        <p className="mt-3 max-w-3xl text-sm font-medium leading-6 text-[#41566C]">
          Aquí se muestran órdenes reales con fecha estimada rebasada, equipos sin movimiento y reparaciones listas que aún no se han entregado.
        </p>
      </section>

      {error && <div className="rounded-2xl border border-red-200 bg-red-50 p-4 text-sm font-bold text-red-700">{error}</div>}
      {loading && <div className="rounded-2xl border border-[#B9D0DF] bg-white p-4 text-sm font-bold text-[#41566C]">Cargando alertas...</div>}

      <section className="grid gap-4 md:grid-cols-4">
        <AlertCard title="Sin movimiento" value={alertas.sinMovimiento.length} subtitle="Más de 3 días" color="#C96A1B" />
        <AlertCard title="Fecha vencida" value={alertas.fechaVencida.length} subtitle="Entrega rebasada" color="#B8860B" />
        <AlertCard title="Sin recoger" value={alertas.sinRecoger.length} subtitle="Listos" color="#2E8B57" />
        <AlertCard title="Órdenes abiertas" value={alertas.abiertas.length} subtitle="En taller" color="#0A84C6" />
      </section>

      <section className="grid gap-5 lg:grid-cols-2">
        <div className="rounded-3xl border border-[#B9D0DF] bg-white p-5 shadow-sm">
          <h2 className="text-xl font-black text-[#07192D]">Fechas rebasadas</h2>
          <p className="mt-1 text-sm text-[#60758B]">Órdenes cuya entrega estimada ya pasó.</p>
          <div className="mt-5 space-y-3">
            {alertas.fechaVencida.length ? alertas.fechaVencida.map((item) => (
              <AlertRow key={getFolio(item)} item={item} label="Entrega estimada vencida" detail={`Fecha estimada: ${getFechaEntrega(item) || "sin fecha"}`} tag="Revisar" />
            )) : <p className="rounded-2xl bg-[#F2F8FC] p-4 text-sm font-semibold text-[#60758B]">No hay órdenes vencidas por ahora.</p>}
          </div>
        </div>

        <div className="rounded-3xl border border-[#B9D0DF] bg-white p-5 shadow-sm">
          <h2 className="text-xl font-black text-[#07192D]">Sin movimiento</h2>
          <p className="mt-1 text-sm text-[#60758B]">Órdenes que llevan más de 3 días sin avance registrado.</p>
          <div className="mt-5 space-y-3">
            {alertas.sinMovimiento.length ? alertas.sinMovimiento.map((item) => (
              <AlertRow key={getFolio(item)} item={item} label="Sin avance reciente" detail={`Último movimiento: ${getLastMove(item) || "sin registro"}`} tag="Prioridad" />
            )) : <p className="rounded-2xl bg-[#F2F8FC] p-4 text-sm font-semibold text-[#60758B]">No hay órdenes atoradas por ahora.</p>}
          </div>
        </div>
      </section>
    </div>
  );
}
