"use client";

import { useEffect, useMemo, useState } from "react";
import Link from "next/link";
import StatusBadge from "@/components/admin/StatusBadge";

const API_URL = process.env.NEXT_PUBLIC_API_URL || "http://localhost:3001";

function normalizeEquipment(item) {
  const cliente = item.cliente || {};
  return {
    id: String(item.id || item.equipoId || item.serial || item.numeroSerie || `${item.marca || ""}-${item.modelo || ""}`),
    type: item.tipo || item.type || "Equipo",
    brand: item.marca || item.brand || "Sin marca",
    model: item.modelo || item.model || "Sin modelo",
    serial: item.numeroSerie || item.serie || item.serial || "Sin serie",
    observations: item.observaciones || item.tag || "Sin observaciones",
    clientId: cliente.id || item.clienteId || "",
    client: cliente.nombre || item.clienteNombre || item.client || "Sin cliente asignado",
    phone: cliente.telefono || item.telefono || item.phone || "Sin teléfono",
    status: item.estado || item.status || "Sin reparación activa",
    currentFolio: item.folioActual || item.currentFolio || "",
    lastService: item.ultimaAtencion || item.lastService || "Sin historial",
  };
}

function normalizeRepair(item) {
  const cliente = item.cliente || {};
  const equipo = item.equipo || {};
  return {
    folio: item.folio,
    estado: item.estado || "recibido",
    fecha: item.fechaIngreso || item.creadoEn || "",
    tecnico: item.tecnico || "Sin asignar",
    recibidoPor: item.recibidoPor || item.creadoPorNombre || "Sin registrar",
    equipoId: String(equipo.id || item.equipoId || equipo.numeroSerie || equipo.serie || ""),
    serie: equipo.numeroSerie || equipo.serie || "",
    type: equipo.tipo || "Equipo",
    brand: equipo.marca || "",
    model: equipo.modelo || "",
    clientId: cliente.id || item.clienteId || "",
    client: cliente.nombre || "Sin cliente",
    lastAdvance: item.historial?.[item.historial.length - 1]?.titulo || "Equipo registrado",
  };
}

function sameText(a, b) {
  return String(a || "").trim().toLowerCase() === String(b || "").trim().toLowerCase();
}

function isRepairForEquipment(repair, equipment) {
  if (!repair || !equipment) return false;
  if (repair.equipoId && repair.equipoId === equipment.id) return true;
  if (repair.serie && equipment.serial !== "Sin serie" && sameText(repair.serie, equipment.serial)) return true;
  if (repair.clientId && equipment.clientId && repair.clientId === equipment.clientId && sameText(`${repair.brand} ${repair.model}`, `${equipment.brand} ${equipment.model}`)) return true;
  if (sameText(repair.client, equipment.client) && sameText(`${repair.brand} ${repair.model}`, `${equipment.brand} ${equipment.model}`)) return true;
  return false;
}

function formatDate(value) {
  if (!value) return "Sin fecha";
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return date.toLocaleDateString("es-MX", { year: "numeric", month: "2-digit", day: "2-digit" });
}

export default function EquipoDetallePage({ params }) {
  const [equipment, setEquipment] = useState([]);
  const [repairs, setRepairs] = useState([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState("");
  const [isEditing, setIsEditing] = useState(false);
  const [editForm, setEditForm] = useState({});
  const [saving, setSaving] = useState(false);
  const id = decodeURIComponent(params.id);

  useEffect(() => {
    let ignore = false;
    async function loadData() {
      try {
        const token = localStorage.getItem("clickcom_token");
        const headers = token ? { Authorization: `Bearer ${token}` } : {};
        const [equipmentResponse, repairsResponse] = await Promise.all([
          fetch(`${API_URL}/api/equipos`, { headers }),
          fetch(`${API_URL}/api/reparaciones`, { headers }),
        ]);
        const equipmentData = await equipmentResponse.json();
        const repairsData = await repairsResponse.json();
        if (!equipmentResponse.ok) throw new Error(equipmentData.error || "No se pudieron cargar los equipos");
        if (!repairsResponse.ok) throw new Error(repairsData.error || "No se pudieron cargar las reparaciones");
        if (!ignore) {
          setEquipment((equipmentData.equipos || []).map(normalizeEquipment));
          setRepairs((repairsData.reparaciones || []).map(normalizeRepair));
        }
      } catch (err) {
        if (!ignore) setError(err.message || "No se pudo cargar la ficha del equipo");
      } finally {
        if (!ignore) setLoading(false);
      }
    }
    loadData();
    return () => {
      ignore = true;
    };
  }, []);

  const item = useMemo(() => equipment.find((entry) => String(entry.id) === String(id)), [equipment, id]);
  const history = useMemo(() => repairs.filter((repair) => isRepairForEquipment(repair, item)), [repairs, item]);
  const activeRepair = history.find((repair) => repair.estado !== "entregado") || null;

  useEffect(() => {
    if (item) {
      setEditForm({
        tipo: item.type,
        marca: item.brand,
        modelo: item.model,
        serie: item.serial,
      });
    }
  }, [item]);

  const handleSave = async (e) => {
    e.preventDefault();
    setSaving(true);
    try {
      const token = localStorage.getItem("clickcom_token");
      const headers = { "Content-Type": "application/json" };
      if (token) headers.Authorization = `Bearer ${token}`;
      
      const res = await fetch(`${API_URL}/api/equipos/${item.id}`, {
        method: "PATCH",
        headers,
        body: JSON.stringify(editForm),
      });
      if (res.ok) {
        const updated = await res.json();
        setEquipment(prev => prev.map(eq => eq.id === item.id ? normalizeEquipment(updated.equipo) : eq));
        setIsEditing(false);
      } else {
        alert("Error al guardar los cambios");
      }
    } catch (err) {
      alert("Error de red");
    } finally {
      setSaving(false);
    }
  };

  if (loading) return <div className="rounded-3xl bg-white p-8 text-[#102033]">Cargando equipo...</div>;

  if (error) {
    return (
      <div className="rounded-3xl border border-[#F4B8B8] bg-[#FFF5F5] p-8 text-[#7F1D1D]">
        <h1 className="text-2xl font-black">No se pudo cargar</h1>
        <p className="mt-2 font-semibold">{error}</p>
      </div>
    );
  }

  if (!item) {
    return (
      <div className="rounded-3xl border border-[#C9D8E5] bg-white p-8">
        <h1 className="text-2xl font-black text-[#102033]">Equipo no encontrado</h1>
        <Link href="/admin/equipos" className="mt-4 inline-flex rounded-2xl bg-[#0077B6] px-5 py-3 text-sm font-black text-white">Volver a equipos</Link>
      </div>
    );
  }

  return (
    <div className="space-y-6">
      <Link href="/admin/equipos" className="inline-flex text-sm font-black text-[#0077B6] hover:underline">← Volver a equipos</Link>

      <section className="rounded-[28px] border border-[#C9D8E5] bg-white p-6 shadow-[0_14px_34px_rgba(15,23,42,0.08)]">
        <div className="flex items-center justify-between">
          <p className="text-xs font-black uppercase tracking-[0.16em] text-[#FF7A00]">Ficha del equipo</p>
          {!isEditing && (
            <button onClick={() => setIsEditing(true)} className="rounded-xl bg-[#F8FBFD] px-4 py-2 text-sm font-black text-[#0077B6] hover:bg-[#E8F1F8]">Editar</button>
          )}
        </div>

        {isEditing ? (
          <form onSubmit={handleSave} className="mt-4 space-y-4">
            <div className="grid gap-4 md:grid-cols-2">
              <div>
                <label className="block text-sm font-black text-[#102033]">Tipo</label>
                <input type="text" value={editForm.tipo || ""} onChange={e => setEditForm({...editForm, tipo: e.target.value})} className="w-full rounded-xl border border-[#C9D8E5] p-3 text-[#102033]" required />
              </div>
              <div>
                <label className="block text-sm font-black text-[#102033]">Marca</label>
                <input type="text" value={editForm.marca || ""} onChange={e => setEditForm({...editForm, marca: e.target.value})} className="w-full rounded-xl border border-[#C9D8E5] p-3 text-[#102033]" required />
              </div>
              <div>
                <label className="block text-sm font-black text-[#102033]">Modelo</label>
                <input type="text" value={editForm.modelo || ""} onChange={e => setEditForm({...editForm, modelo: e.target.value})} className="w-full rounded-xl border border-[#C9D8E5] p-3 text-[#102033]" required />
              </div>
              <div>
                <label className="block text-sm font-black text-[#102033]">Número de serie</label>
                <input type="text" value={editForm.serie || ""} onChange={e => setEditForm({...editForm, serie: e.target.value})} className="w-full rounded-xl border border-[#C9D8E5] p-3 text-[#102033]" required />
              </div>
            </div>
            <div className="flex justify-end space-x-3 mt-4">
              <button type="button" onClick={() => setIsEditing(false)} className="rounded-xl px-4 py-2 text-sm font-black text-[#526174]">Cancelar</button>
              <button type="submit" disabled={saving} className="rounded-xl bg-[#0077B6] px-5 py-2 text-sm font-black text-white">{saving ? "Guardando..." : "Guardar Cambios"}</button>
            </div>
          </form>
        ) : (
          <>
            <div className="mt-2 flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
              <div>
                <h1 className="text-3xl font-black text-[#102033]">{item.brand} {item.model}</h1>
                <p className="mt-2 text-sm font-bold text-[#526174]">{item.type}</p>
              </div>
              {activeRepair ? <StatusBadge status={activeRepair.estado} /> : <span className="rounded-full border border-[#C8D6E3] bg-[#F2F7FA] px-3 py-1 text-xs font-black text-[#526174]">Sin reparación activa</span>}
            </div>

            <div className="mt-5 grid gap-3 md:grid-cols-3">
              <Info label="Número de serie" value={item.serial} />
              <Info label="Cliente" value={item.client} />
              <Info label="Teléfono" value={item.phone} />
              <Info label="Reparaciones" value={history.length} />
              <Info label="Folio actual" value={activeRepair?.folio || item.currentFolio || "Sin folio activo"} />
              <Info label="Última atención" value={history[0] ? formatDate(history[0].fecha) : item.lastService} />
            </div>
          </>
        )}
      </section>

      <section id="historial" className="rounded-[28px] border border-[#C9D8E5] bg-white p-6 shadow-[0_14px_34px_rgba(15,23,42,0.08)]">
        <div className="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
          <div>
            <h2 className="text-xl font-black text-[#102033]">Historial del equipo</h2>
            <p className="mt-1 text-sm leading-6 text-[#526174]">Reparaciones vinculadas a este mismo equipo.</p>
          </div>
          {activeRepair ? (
            <Link href={`/admin/reparaciones/${activeRepair.folio}`} className="inline-flex rounded-2xl bg-[#0077B6] px-5 py-3 text-sm font-black text-white hover:bg-[#00669C]">
              Abrir reparación actual
            </Link>
          ) : null}
        </div>

        {history.length === 0 ? (
          <div className="mt-5 rounded-2xl border border-dashed border-[#C9D8E5] bg-[#F8FBFD] p-5 text-sm font-semibold text-[#526174]">
            Este equipo todavía no tiene reparaciones vinculadas.
          </div>
        ) : (
          <div className="mt-5 overflow-x-auto rounded-2xl border border-[#D9E6EF]">
            <table className="w-full min-w-[760px] text-left">
              <thead className="bg-[#EAF3F9] text-xs font-black uppercase tracking-[0.12em] text-[#526174]">
                <tr>
                  <th className="px-4 py-3">Folio</th>
                  <th className="px-4 py-3">Fecha</th>
                  <th className="px-4 py-3">Estado</th>
                  <th className="px-4 py-3">Recibió</th>
                  <th className="px-4 py-3">Técnico</th>
                  <th className="px-4 py-3">Último avance</th>
                  <th className="px-4 py-3 text-right">Acción</th>
                </tr>
              </thead>
              <tbody>
                {history.map((repair) => (
                  <tr key={repair.folio} className="border-t border-[#D9E6EF] bg-white">
                    <td className="px-4 py-3 font-black text-[#0077B6]">{repair.folio}</td>
                    <td className="px-4 py-3 font-semibold text-[#102033]">{formatDate(repair.fecha)}</td>
                    <td className="px-4 py-3"><StatusBadge status={repair.estado} /></td>
                    <td className="px-4 py-3 font-semibold text-[#102033]">{repair.recibidoPor}</td>
                    <td className="px-4 py-3 font-semibold text-[#102033]">{repair.tecnico}</td>
                    <td className="px-4 py-3 font-semibold text-[#526174]">{repair.lastAdvance}</td>
                    <td className="px-4 py-3 text-right"><Link href={`/admin/reparaciones/${repair.folio}`} className="font-black text-[#0077B6] hover:underline">Ver</Link></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </section>
    </div>
  );
}

function Info({ label, value }) {
  return (
    <div className="rounded-2xl border border-[#C9D8E5] bg-[#F8FBFD] p-4">
      <p className="text-xs font-black uppercase tracking-[0.12em] text-[#526174]">{label}</p>
      <p className="mt-1 font-black text-[#102033]">{value}</p>
    </div>
  );
}