"use client";

import { useEffect, useState } from "react";
import { useSearchParams } from "next/navigation";
import RepairDetail from "@/components/admin/RepairDetail";
import { dedupePhotos, formatDateOnly, formatDateTime } from "@/lib/adminFormat";

const API_URL = process.env.NEXT_PUBLIC_API_URL || "http://localhost:3001";

function statusLabel(status) {
  const labels = {
    recibido: "Recibido",
    diagnostico: "Diagnóstico",
    en_reparacion: "En reparación",
    esperando_refaccion: "Esperando refacción",
    finalizado: "Finalizado",
    entregado: "Entregado",
  };

  return labels[status] || status || "Recibido";
}

function mapRepair(data, mensaje) {
  if (!data) return null;

  const equipo = data.equipo || {};
  const cliente = data.cliente || {};
  const historial = Array.isArray(data.historial) ? data.historial : [];
  const photos = dedupePhotos([...(data.fotos || []), ...(data.fotosRecepcion || []), ...(equipo.fotosRecepcion || [])]);

  return {
    folio: data.folio,
    client: cliente.nombre || "Sin cliente",
    phone: cliente.telefono || "Sin teléfono",
    email: cliente.correo || "",
    device: [equipo.marca, equipo.modelo].filter(Boolean).join(" ") || "Equipo registrado",
    deviceType: equipo.tipo || "Equipo",
    brand: equipo.marca || "",
    model: equipo.modelo || "",
    serialNumber: equipo.serie || "",
    type: "Orden de servicio",
    status: data.estado || "recibido",
    statusLabel: statusLabel(data.estado || "recibido"),
    tech: data.tecnico || "Sin asignar",
    receivedBy: data.recibidoPor || data.creadoPorNombre || "Sin registrar",
    entryTime: data.horaEntrada || "Sin registrar",
    priority: "Media",
    problem: data.fallaReportada || "Sin falla registrada",
    observations: data.observacionesRecepcion || data.observacionesCliente || "",
    accessories: equipo.accesorios || data.accesorios || [],
    physicalConditions: data.estadoFisico || equipo.estadoFisico || [],
    photos,
    payment: data.pago || {},
    advance: data.anticipo || {},
    warranty: data.garantia || {},
    devicePassword: equipo.passwordEquipo || "",
    dateIn: formatDateOnly(data.fechaIngreso || data.creadoEn),
    dateEstimated: formatDateOnly(data.fechaEntregaEstimada, "Sin definir"),
    trackingUrl: mensaje?.link || "",
    timeline: historial.map((item) => ({
      title: item.titulo || item.estado || "Actualización",
      date: formatDateTime(item.fecha),
      description: item.descripcion || "",
      tech: item.tecnico || data.tecnico || "Taller",
      color:
        item.estado === "entregado"
          ? "#22C55E"
          : item.estado === "en_reparacion"
            ? "#0066FF"
            : "#FF6B2C",
    })),
  };
}

export default function RepairDetailPage({ params }) {
  const [repair, setRepair] = useState(null);
  const [loading, setLoading] = useState(true);
  const searchParams = useSearchParams();

  useEffect(() => {
    async function loadRepair() {
      try {
        const token = localStorage.getItem("clickcom_token");
        const response = await fetch(`${API_URL}/api/reparaciones/${params.id}`, {
          headers: token ? { Authorization: `Bearer ${token}` } : {},
        });
        if (!response.ok) throw new Error("No encontrada");

        const data = await response.json();
        setRepair(mapRepair(data.reparacion, data.mensaje));
      } catch {
        setRepair(null);
      } finally {
        setLoading(false);
      }
    }

    loadRepair();
  }, [params.id]);

  useEffect(() => {
    if (!loading && repair && searchParams.get("print") === "1") {
      const timer = setTimeout(() => window.print(), 350);
      return () => clearTimeout(timer);
    }
  }, [loading, repair, searchParams]);

  if (loading) {
    return (
      <div className="rounded-2xl border border-[#D5E2EC] bg-white p-6 font-bold text-[#102033]">
        Cargando reparación...
      </div>
    );
  }

  return <RepairDetail repair={repair} />;
}
