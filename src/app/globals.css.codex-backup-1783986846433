/* ============================================================
   src/styles/globals.css
   Estilos globales de CLICK.COM Caribe
   ============================================================ */

@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800;900&family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=JetBrains+Mono:wght@400;500&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

/* === Variables CSS globales — modificar para cambiar tema === */
:root {
  --font-admin: var(--font-inter), Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  --color-electric: #0066FF;
  --color-accent: #FF6B00;
  --color-surface: #0A0E1A;
  --color-card: #0F1528;
  --color-border: #1A2240;
  --color-text-primary: #F0F4FF;
  --color-text-secondary: #8899CC;
}

@layer base {
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: #EEF4F8;
    color: #F0F4FF;
    font-family: 'DM Sans', sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  ::selection {
    background-color: rgba(0, 102, 255, 0.35);
    color: #F0F4FF;
  }

  /* Scrollbar personalizada */
  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: #0A0E1A;
  }
  ::-webkit-scrollbar-thumb {
    background: #1A2240;
    border-radius: 3px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #0066FF66;
  }
}

@layer utilities {
  /* Texto con gradiente eléctrico */
  .text-electric-gradient {
    background: linear-gradient(135deg, #3385FF 0%, #0066FF 50%, #FF6B00 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Borde con glow */
  .border-electric-glow {
    border: 1px solid rgba(0, 102, 255, 0.3);
    box-shadow: 0 0 20px rgba(0, 102, 255, 0.08), inset 0 0 20px rgba(0, 102, 255, 0.03);
  }

  /* Efecto glassmorphism oscuro */
  .glass-dark {
    background: rgba(15, 21, 40, 0.8);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  /* Línea decorativa eléctrica */
  .electric-line {
    height: 1px;
    background: linear-gradient(90deg, transparent, #0066FF, transparent);
  }

  /* Indicador de estado activo */
  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #0066FF;
    box-shadow: 0 0 8px #0066FF;
    animation: glowPulse 2s ease-in-out infinite;
  }
}
@keyframes bar-grow {
  from {
    transform: scaleY(0);
    transform-origin: bottom;
  }
  to {
    transform: scaleY(1);
    transform-origin: bottom;
  }
}

@keyframes count-up {
  from {
    opacity: 0;
    transform: translateY(4px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media print {
  body {
    background: #ffffff !important;
    color: #111827 !important;
  }

  .no-print,
  .admin-app-shell > aside,
  .admin-app-shell header {
    display: none !important;
  }

  .admin-app-shell,
  .admin-main {
    display: block !important;
    height: auto !important;
    min-height: 0 !important;
    overflow: visible !important;
    background: #ffffff !important;
    padding: 0 !important;
  }

  .repair-print-area {
    display: block !important;
    width: 100% !important;
    max-width: none !important;
    background: #ffffff !important;
    color: #111827 !important;
    padding: 18px !important;
  }

  .repair-print-area * {
    box-shadow: none !important;
  }
}


