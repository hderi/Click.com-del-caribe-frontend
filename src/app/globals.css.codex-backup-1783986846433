/* CLICKCOM_ENTERPRISE_FINAL_START */
:root {
  --cc-font: var(--font-inter), Inter, ui-sans-serif, system-ui, -apple-system, "Segoe UI", Arial, sans-serif;
  --cc-bg: #e7f0f6;
  --cc-page: #edf5f9;
  --cc-panel: #ffffff;
  --cc-panel-soft: #f7fafc;
  --cc-head: #e8f2f8;
  --cc-line: #c6d7e4;
  --cc-line-soft: #dce8f0;
  --cc-text: #102033;
  --cc-muted: #5d7188;
  --cc-accent: #0088c7;
  --cc-accent-dark: #006f9f;
  --cc-orange: #c76510;
  --cc-green: #18794e;
  --cc-red: #b42318;
}

html, body {
  font-family: var(--cc-font) !important;
  font-size: 14px;
  color: var(--cc-text);
}

* {
  font-family: var(--cc-font) !important;
  letter-spacing: 0 !important;
}

.admin-theme {
  min-height: 100vh;
  background: var(--cc-bg) !important;
  color: var(--cc-text) !important;
  font-size: 13px !important;
}

.admin-theme .glass,
.admin-theme .glass-strong,
.admin-theme [class*="backdrop-blur"],
.admin-theme [class*="bg-gradient"],
.admin-theme [class*="from-"],
.admin-theme [class*="via-"],
.admin-theme [class*="to-"] {
  background-image: none !important;
  backdrop-filter: none !important;
}

.admin-theme [class*="shadow"] {
  box-shadow: none !important;
}

.admin-theme [class*="rounded-2xl"],
.admin-theme [class*="rounded-xl"],
.admin-theme [class*="rounded-lg"] {
  border-radius: 8px !important;
}

.admin-theme aside,
.admin-theme nav {
  background: #eaf3f8 !important;
  border-color: var(--cc-line) !important;
}

.admin-theme main,
.admin-theme section {
  background: transparent !important;
}

.admin-theme article,
.admin-theme form,
.admin-theme .glass,
.admin-theme .glass-strong,
.admin-theme [class*="bg-white"],
.admin-theme [class*="bg-surface"],
.admin-theme [class*="bg-[#F"],
.admin-theme [class*="bg-[#f"] {
  background-color: var(--cc-panel) !important;
  border: 1px solid var(--cc-line) !important;
}

.admin-theme h1 {
  font-size: 24px !important;
  line-height: 1.18 !important;
  font-weight: 750 !important;
  color: var(--cc-text) !important;
}

.admin-theme h2 {
  font-size: 18px !important;
  line-height: 1.25 !important;
  font-weight: 740 !important;
  color: var(--cc-text) !important;
}

.admin-theme h3 {
  font-size: 15px !important;
  line-height: 1.3 !important;
  font-weight: 720 !important;
  color: var(--cc-text) !important;
}

.admin-theme p,
.admin-theme label,
.admin-theme span,
.admin-theme li {
  font-size: 13px;
  line-height: 1.45;
}

.admin-theme input,
.admin-theme select,
.admin-theme textarea {
  border: 1px solid var(--cc-line) !important;
  border-radius: 7px !important;
  min-height: 38px;
  background: #fff !important;
  color: var(--cc-text) !important;
  font-size: 13px !important;
  outline: none !important;
}

.admin-theme input:focus,
.admin-theme select:focus,
.admin-theme textarea:focus {
  border-color: var(--cc-accent) !important;
  box-shadow: 0 0 0 2px rgba(0, 136, 199, 0.14) !important;
}

.admin-theme input::placeholder,
.admin-theme textarea::placeholder {
  color: #7e92a6 !important;
}

.admin-theme button,
.admin-theme a[class*="rounded"] {
  border-radius: 7px !important;
  font-size: 13px !important;
  font-weight: 650 !important;
}

.admin-theme button[class*="bg-brand"],
.admin-theme button[class*="bg-[#"],
.admin-theme a[class*="bg-brand"],
.admin-theme a[class*="bg-[#"] {
  background: var(--cc-accent) !important;
  color: #fff !important;
  border-color: var(--cc-accent) !important;
}

.admin-theme button:hover,
.admin-theme a:hover {
  filter: none !important;
}

.admin-theme table {
  width: 100%;
  border-collapse: collapse;
  background: #fff;
}

.admin-theme thead tr,
.admin-theme table th {
  background: var(--cc-head) !important;
  color: #43576f !important;
  font-size: 11px !important;
  font-weight: 750 !important;
  text-transform: uppercase;
  border-bottom: 1px solid var(--cc-line) !important;
  padding: 9px 12px !important;
}

.admin-theme table td {
  color: var(--cc-text) !important;
  font-size: 13px !important;
  border-bottom: 1px solid var(--cc-line-soft) !important;
  padding: 10px 12px !important;
  vertical-align: middle;
}

.admin-theme tbody tr:hover {
  background: #f5f9fc !important;
}

.admin-theme .cc-card {
  background: #fff;
  border: 1px solid var(--cc-line);
  border-radius: 8px;
}

@media print {
  .admin-theme aside,
  .admin-theme nav,
  .admin-theme .no-print,
  .no-print {
    display: none !important;
  }
  .admin-theme {
    background: #fff !important;
  }
}
/* CLICKCOM_ENTERPRISE_FINAL_END */
