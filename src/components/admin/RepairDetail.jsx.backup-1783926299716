function getAuthHeaders(extra = {}) {
  if (typeof window === "undefined") return extra;
  const token = localStorage.getItem("clickcom_token") || "";
  return { ...extra, ...(token ? { Authorization: `Bearer ${token}` } : {}) };
}

const STATUS_OPTIONS = [
  { value: "recibido", label: "Recibido" },
  { value: "diagnostico", label: "Diagnóstico" },
  { value: "en_reparacion", label: "En reparación" },
  { value: "esperando_refaccion", label: "Esperando refacción" },
  { value: "finalizado", label: "Finalizado" },
  { value: "entregado", label: "Entregado" },
];

function labelStatus(value) {
  return STATUS_OPTIONS.find((item) => item.value === value)?.label || value || "Recibido";
}

function money(value) {
  const number = Number(value || 0);
  return number.toLocaleString("es-MX", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

